<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/editTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_title" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_week_days" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/cbMon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/day_short_mon" />

            <CheckBox
                android:id="@+id/cbTue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/day_short_tue" />

            <CheckBox
                android:id="@+id/cbWed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/day_short_wed" />

            <CheckBox
                android:id="@+id/cbThu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/day_short_thu" />

            <CheckBox
                android:id="@+id/cbFri"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/day_short_fri" />

            <CheckBox
                android:id="@+id/cbSat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/day_short_sat" />

            <CheckBox
                android:id="@+id/cbSun"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/day_short_sun" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/label_time" />

        <TextView
            android:id="@+id/tvSelectedTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/value_not_set" />

        <Button
            android:id="@+id/btnPickTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_select_time" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_repeat_every" />

        <Spinner
            android:id="@+id/spinnerWeeks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_month_days" />

        <TextView
            android:id="@+id/tvMonthDaysValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/value_all_month_days" />

        <Button
            android:id="@+id/btnSelectMonthDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_select_month_days" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/label_year_months" />

        <TextView
            android:id="@+id/tvYearMonthsValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/value_all_year_months" />

        <Button
            android:id="@+id/btnSelectYearMonths"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_select_year_months" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/label_monthly_pattern" />

        <Spinner
            android:id="@+id/spinnerMonthlyPattern"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/label_start_date" />

        <TextView
            android:id="@+id/tvStartDateValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/value_not_set" />

        <Button
            android:id="@+id/btnPickStartDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_select_start_date" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/label_end_date" />

        <TextView
            android:id="@+id/tvEndDateValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/value_no_end_date" />

        <Button
            android:id="@+id/btnPickEndDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_select_end_date" />

        <Button
            android:id="@+id/btnClearEndDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/action_clear_end_date" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/action_save" />

    </LinearLayout>

</ScrollView>
